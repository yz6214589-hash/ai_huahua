@startuml
!include _style.puml

title 数据库：RAG SQLite 物理模型（documents.db）

hide circle
skinparam linetype ortho

entity "documents" as doc <<DB>> {
  * doc_id : text <<PK>>
  --
  filename : text
  path : text
  sha256 : text
  size_bytes : integer
  mtime_ns : integer
  title : text
  stock_name : text
  stock_code : text
  source : text
  report_type : text
  publish_date : text
  created_at : text
  updated_at : text
}

entity "chunks" as chunk <<DB>> {
  * chunk_id : text <<PK>>
  --
  doc_id : text <<FK>>
  page : integer
  chunk_index : integer
  content : text
  content_sha256 : text
  stock_name : text
  stock_code : text
  title : text
  source : text
  report_type : text
  publish_date : text
  indexed : integer
  created_at : text
  --
  idx_chunks_doc(doc_id)
  idx_chunks_indexed(indexed)
  idx_chunks_stock_code(stock_code)
  idx_chunks_stock_name(stock_name)
}

chunk }o--|| doc : doc_id

note right of chunk
RAG 索引落盘位置：.ai_quant/reports_rag/\n- documents.db\n- vector_store/index.faiss\n- vector_store/index.pkl\n路径定义见 services/reports/rag.py
end note

@enduml
