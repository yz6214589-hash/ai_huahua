@startuml
!include _style.puml

title 信息架构：导航结构（Navigation）

package "侧边栏（一级导航）" <<UI>> #ECFDF5 {
  rectangle "总览 /" as nav_home <<UI>>
  rectangle "采集任务 /jobs" as nav_jobs <<UI>>
  rectangle "智能研报 /reports" as nav_reports <<UI>>
  rectangle "舆情监控 /sentiment" as nav_sentiment <<UI>>
  rectangle "执行监控 /execution" as nav_execution <<UI>>
  rectangle "风控中心 /risk" as nav_risk <<UI>>
  rectangle "策略分析 /strategy" as nav_strategy <<UI>>
  rectangle "晨会简报 /morning" as nav_morning <<UI>>
  rectangle "AI 对话 /chat" as nav_chat <<UI>>
  rectangle "数据与交付 /data" as nav_data <<UI>>
  rectangle "自选股 /watchlist" as nav_watch <<UI>>
}

package "二级/详情路由" <<UI>> #ECFDF5 {
  rectangle "个股详情 /stock/:code" as nav_stock <<UI>>
  rectangle "舆情运行详情 /sentiment/runs/:runId" as nav_sentiment_run <<UI>>
  rectangle "舆情个股详情 /sentiment/stocks/:code" as nav_sentiment_stock <<UI>>
}

nav_data --> nav_stock : 点击某只股票
nav_watch --> nav_stock : 点击某只股票
nav_sentiment --> nav_sentiment_run : 查看某次运行
nav_sentiment --> nav_sentiment_stock : 查看某只股票

note right of nav_data
顶栏搜索框 Enter 默认跳转到 /data?stock_code=xxx\n并可从 /data 或 /watchlist 进入 /stock/:code
end note

@enduml
