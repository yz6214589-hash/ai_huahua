@startuml
!include _style.puml

title AI Quant 分层视图（Layered View）

package "表示层" <<UI>> #ECFDF5 {
  rectangle "Web（React/Vite）" as web <<UI>>
  rectangle "Streamlit Chat" as st <<UI>>
}

package "API 层" <<API>> #EFF6FF {
  rectangle "FastAPI Router\n/backend/ai_quant_api/api/*" as api <<API>>
}

package "业务/集成层" <<SVC>> #EEF2FF {
  rectangle "Agent / LangGraph\n(ai_quant_api/ai/*)" as agent <<SVC>>
  rectangle "Services 集成\n(services/*)" as svc <<SVC>>
}

package "数据层" <<DB>> #EFF6FF {
  database "MySQL\nhuahua_trade" as mysql <<DB>>
  database "SQLite\nRAG documents.db" as sqlite <<DB>>
  rectangle "FAISS\nindex.faiss/index.pkl" as faiss <<DB>>
}

package "运行时目录" <<RUNTIME>> #FFF7ED {
  folder ".ai_quant/\n- reports_worker.log\n- report_outputs/\n- reports_rag/" as rt <<RUNTIME>>
}

web --> api : /api/*
st --> api : /api/agent/run
api --> agent
api --> svc
svc --> mysql
svc --> sqlite
svc --> faiss
agent --> svc
api --> rt : 日志/产物落盘
svc --> rt : 索引/文档落盘

note right of rt
`.ai_quant` 是运行时工作目录\n用于日志、研报产物、RAG 文档/索引\n与源码分离，便于挂载与备份
end note

@enduml
