@startuml
!include _style.puml

title 前端交互：智能研报页面流程（/reports）

start
:进入 /reports;
:loadTasks() 拉取任务列表;
repeat
  :每 1.5s 轮询刷新任务列表;
repeat while (页面未卸载?) is (是)

fork
  :选择模型 qwen-max 或 deepseek;
fork again
  :输入股票代码/名称;
  :150ms 防抖;
  if (命中缓存?) then (是)
    :展示缓存结果;
  else (否)
    :调用 /api/stocks?q=...&limit=20;
    if (超时/失败?) then (是)
      :展示“搜索超时或失败”;
    else (否)
      :展示结果列表;
    endif
  endif
  :选择股票（可多选）;
  :写入本地 recent 列表;
end fork

if (已选择股票?) then (是)
  :POST /api/reports/tasks\n{ model, stock_codes[] };
  :清空选中与输入;
else (否)
  :提示“请先选择股票”;
endif

if (任务状态 success?) then (是)
  :点击“查看”打开\n/api/reports/tasks/{id}/view;
else (否)
  if (任务状态 failed?) then (是)
    :查看接口返回 500 文本错误;
  else (否)
    :返回 409 report not ready;
  endif
endif

stop
@enduml
