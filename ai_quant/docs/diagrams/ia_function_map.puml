@startuml
!include _style.puml

title 信息架构：功能地图（Function Map）

package "用户侧能力" <<UI>> #ECFDF5 {
  rectangle "总览\n/" as ui_home <<UI>>
  rectangle "采集任务\n/jobs" as ui_jobs <<UI>>
  rectangle "智能研报\n/reports" as ui_reports <<UI>>
  rectangle "舆情监控\n/sentiment" as ui_sentiment <<UI>>
  rectangle "执行监控\n/execution" as ui_exec <<UI>>
  rectangle "风控中心\n/risk" as ui_risk <<UI>>
  rectangle "策略分析\n/strategy" as ui_strategy <<UI>>
  rectangle "晨会简报\n/morning" as ui_morning <<UI>>
  rectangle "AI 对话\n/chat" as ui_chat <<UI>>
  rectangle "数据与交付\n/data" as ui_data <<UI>>
  rectangle "自选股\n/watchlist" as ui_watch <<UI>>
  rectangle "个股详情\n/stock/:code" as ui_stock <<UI>>
}

package "系统能力（后端）" <<API>> #EFF6FF {
  rectangle "健康检查\n/api/health" as api_health <<API>>
  rectangle "数据汇总\n/api/summary" as api_summary <<API>>
  rectangle "数据查询与导出\n/api/data/*" as api_data <<API>>
  rectangle "自选股管理\n/api/watchlist/*" as api_watch <<API>>
  rectangle "任务运行记录\n/api/jobs/*" as api_jobs <<API>>
  rectangle "智能研报\n/api/reports/*" as api_reports <<API>>
  rectangle "舆情监控（规划）\n/api/sentiment/*" as api_sentiment <<API>>
  rectangle "分析服务\n/api/analysis/*" as api_analysis <<API>>
  rectangle "交易执行\n/api/execution/*" as api_execution <<API>>
  rectangle "交易连接\n/api/trading/*" as api_trading <<API>>
  rectangle "风控\n/api/risk/*" as api_risk <<API>>
  rectangle "控制台/晨会\n/api/console/*" as api_console <<API>>
  rectangle "AI Agent\n/api/agent/*" as api_agent <<API>>
}

ui_home --> api_summary
ui_jobs --> api_jobs
ui_reports --> api_reports
ui_sentiment ..> api_sentiment
ui_data --> api_data
ui_watch --> api_watch
ui_exec --> api_execution
ui_risk --> api_risk
ui_morning --> api_console
ui_chat --> api_agent

note right of ui_reports
研报数据链路依赖 `.ai_quant`\n日志与产物可被 Docker volume 挂载持久化
end note

@enduml
